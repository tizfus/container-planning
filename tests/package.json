    "test:html-report": "cucumber-js --format html:cucumber-report.html"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "playwright": "^1.61.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
